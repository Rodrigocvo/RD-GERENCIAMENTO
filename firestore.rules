rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Bets collection
    match /bets/{betId} {
      function isValidBet(data) {
        return data.userId == request.auth.uid &&
               data.date is string &&
               data.event is string && data.event.size() <= 200 &&
               data.market is string && data.market.size() <= 200 &&
               data.odds is string && data.odds.size() <= 20 &&
               data.stake is string && data.stake.size() <= 20 &&
               data.result in ['win', 'loss', 'pending', 'Ganha', 'Perdida'] &&
               (data.bonusPercent == null || data.bonusPercent is string) &&
               (data.roi == null || data.roi is string) &&
               data.type in ['win', 'loss'] &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }

      allow create: if isSignedIn() && isValidBet(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isOwner(resource.data.userId) && isValidBet(request.resource.data) && request.resource.data.updatedAt == request.time && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
      allow list, get: if isOwner(resource.data.userId);
    }

    // Settings collection
    match /settings/{userId} {
      function isValidSettings(data) {
        return data.userId == request.auth.uid &&
               data.initialBankroll is number &&
               data.isDark is bool &&
               data.updatedAt is timestamp;
      }

      allow create: if isOwner(userId) && isValidSettings(request.resource.data);
      allow update: if isOwner(userId) && isValidSettings(request.resource.data) && request.resource.data.updatedAt == request.time;
      allow get: if isOwner(userId);
    }
  }
}
